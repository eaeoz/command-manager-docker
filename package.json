{
  "name": "command-manager",
  "version": "1.0.1",
  "description": "SSH Command Manager with GUI",
  "main": "src/main/main.js",
  "scripts": {
    "start": "nodemon app.js",
    "electron": "electron .",
    "build": "electron-builder --win --x64 --publish never",
    "build:dir": "electron-builder --win --x64 --dir --publish never"
  },
  "pkg": {
    "targets": ["node18-win-x64"]
  },
  "keywords": [],
  "author": {
    "name": "Sedat Ergoz",
    "email": "sedatergoz@gmail.com"
  },
  "license": "ISC",
  "dependencies": {
    "body-parser": "^1.20.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "font-awesome": "^4.7.0",
    "fs": "^0.0.1-security",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "nodemon": "^3.1.7",
    "png-to-ico": "^3.0.1"
  },
  "build": {
    "appId": "com.commandmanager.app",
    "productName": "Command Manager",
    "copyright": "Copyright © 2024 Sedat Ergoz",
    "directories": {
      "output": "dist"
    },
    "asar": false,
    "electronDownload": {
      "cache": "dist/electron-cache"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "data/gear.ico",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "${productName}_portable_${version}.${ext}"
    },
    "nsis": {
      "installerIcon": "data/gear.ico",
      "uninstallerIcon": "data/gear.ico",
      "installerHeaderIcon": "data/gear.ico"
    },
    "files": [
      "app.js",
      "src/**/*",
      "data/**/*",
      "config/**/*",
      "package.json"
    ]
  }
}
